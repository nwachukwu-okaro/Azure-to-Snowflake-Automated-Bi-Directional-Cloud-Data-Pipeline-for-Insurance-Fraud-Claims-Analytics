--------------------BUILDING CURATED BUSINESS CASE Views/TABLES FOR OTHER TEAMS 

------Building fraud alert view

CREATE OR REPLACE VIEW fraud_risk_alerts_view AS
WITH latest_claims AS (
    SELECT 
        *,
        -- STEP 1: Map the text labels to numbers
        CASE 
            WHEN fraud_risk_score = 'High'   THEN 90
            WHEN fraud_risk_score = 'Medium' THEN 50
            WHEN fraud_risk_score = 'Low'    THEN 20
            ELSE 0 
        END AS mapped_risk_score
    FROM insurance_claims
    QUALIFY ROW_NUMBER() OVER (
        PARTITION BY claim_id
        ORDER BY last_updated_timestamp DESC
    ) = 1
)
SELECT
    c.claim_id,
    c.policy_id,
    p.customer_id,
    cd.first_name,
    cd.last_name,
    p.policy_type,
    p.region,
    TRY_TO_DATE(c.claim_date) AS claim_date,
    TRY_TO_DATE(c.settlement_date) AS settlement_date,
    TRY_TO_DATE(p.policy_start_date) AS policy_start_date,
    c.claim_type,
    c.claim_amount,
    c.approved_amount,
    c.claim_status,
    c.fraud_risk_score AS original_risk_label,


    CASE
        WHEN c.mapped_risk_score >= 80 THEN 1
        WHEN c.claim_amount > 50000 THEN 1
        WHEN c.claim_status = 'Under Investigation' THEN 1
        WHEN DATEDIFF(day, TRY_TO_DATE(p.policy_start_date), TRY_TO_DATE(c.claim_date)) BETWEEN 0 AND 30 THEN 1
        WHEN c.settlement_date IS NOT NULL
             AND DATEDIFF(day, TRY_TO_DATE(c.claim_date), TRY_TO_DATE(c.settlement_date)) < 5 THEN 1
        WHEN c.claim_status IN ('Open', 'Pending')
             AND DATEDIFF(day, TRY_TO_DATE(c.claim_date), CURRENT_DATE()) > 90 THEN 1
        ELSE 0
    END AS is_high_risk,

    
    CASE
        WHEN c.mapped_risk_score >= 80 THEN 'High Risk Score'
        WHEN c.claim_amount > 50000 THEN 'Large Loss'
        WHEN c.claim_status = 'Under Investigation' THEN 'Under Investigation'
        WHEN DATEDIFF(day, TRY_TO_DATE(p.policy_start_date), TRY_TO_DATE(c.claim_date)) BETWEEN 0 AND 30
            THEN 'Early Claim'
        WHEN c.settlement_date IS NOT NULL
             AND DATEDIFF(day, TRY_TO_DATE(c.claim_date), TRY_TO_DATE(c.settlement_date)) < 5
            THEN 'Suspicious Fast Settlement'
        WHEN c.claim_status IN ('Open', 'Pending')
             AND DATEDIFF(day, TRY_TO_DATE(c.claim_date), CURRENT_DATE()) > 90
            THEN 'Long Pending Claim'
        ELSE 'Standard Review'
    END AS risk_category

FROM latest_claims c
JOIN insurance_policy_master p ON c.policy_id = p.policy_id
JOIN customer_demographics cd ON p.customer_id = cd.customer_id;


SELECT * FROM fraud_risk_alerts_view;




--------CLAIM CYCLE TIME SUMMARY


CREATE OR REPLACE VIEW claims_cycle_time_summary_view AS
SELECT
  c.claim_id,
  c.policy_id,
  p.customer_id,
  p.region,
  c.adjuster_id,
  c.claim_type,
  c.claim_status,
  c.claim_date,
  c.settlement_date,
  DATEDIFF('day', c.claim_date, c.settlement_date) AS cycle_time_days
FROM insurance_claims_view c
JOIN insurance_policy_master_view p
  ON c.policy_id = p.policy_id;

SELECT * FROM claims_cycle_time_summary_view;



--------Customer Lifetime value 

CREATE OR REPLACE VIEW customer_lifetime_value_view AS
WITH premiums AS (
  SELECT
    p.customer_id,
    SUM(p.annual_premium) AS total_premium
  FROM insurance_policy_master_view p
  GROUP BY p.customer_id
),
claims AS (
  SELECT
    p.customer_id,
    SUM(c.approved_amount) AS total_claims_paid
  FROM insurance_claims_view c
  JOIN insurance_policy_master_view p
    ON c.policy_id = p.policy_id
  GROUP BY p.customer_id
)
SELECT
  cd.customer_id,
  cd.first_name,
  cd.last_name,
  cd.customer_since_date,
  DATEDIFF('day', cd.customer_since_date, CURRENT_DATE()) AS tenure_days,
  COALESCE(pr.total_premium, 0) AS total_premium,
  COALESCE(cl.total_claims_paid, 0) AS total_claims_paid,
  COALESCE(pr.total_premium, 0) - COALESCE(cl.total_claims_paid, 0) AS customer_lifetime_value
FROM customer_demographics_view cd
LEFT JOIN premiums pr
  ON cd.customer_id = pr.customer_id
LEFT JOIN claims cl
  ON cd.customer_id = cl.customer_id;

SELECT * FROM customer_lifetime_value_view;



------Loss Ratio Summary

CREATE OR REPLACE VIEW loss_ratio_summary_view AS
WITH policy_premiums AS (
  SELECT
    p.region,
    p.policy_type,
    DATE_TRUNC('month', p.policy_start_date) AS month_start,
    SUM(p.annual_premium) AS total_premium
  FROM insurance_policy_master_view p
  GROUP BY p.region, p.policy_type, DATE_TRUNC('month', p.policy_start_date)
),
claims_paid AS (
  SELECT
    p.region,
    p.policy_type,
    DATE_TRUNC('month', c.claim_date) AS month_start,
    SUM(c.approved_amount) AS total_claims_paid
  FROM insurance_claims_view c
  JOIN insurance_policy_master_view p
    ON c.policy_id = p.policy_id
  GROUP BY p.region, p.policy_type, DATE_TRUNC('month', c.claim_date)
)
SELECT
  pp.region,
  pp.policy_type,
  pp.month_start,
  pp.total_premium,
  COALESCE(cp.total_claims_paid, 0) AS total_claims_paid,
  CASE
    WHEN pp.total_premium = 0 THEN NULL
    ELSE cp.total_claims_paid / pp.total_premium
  END AS loss_ratio
FROM policy_premiums pp
LEFT JOIN claims_paid cp
  ON pp.region = cp.region
 AND pp.policy_type = cp.policy_type
 AND pp.month_start = cp.month_start;

SELECT * FROM loss_ratio_summary_view;



