USE ROLE ACCOUNTADMIN;

CREATE OR REPLACE STORAGE INTEGRATION azure_int
  TYPE = EXTERNAL_STAGE
  STORAGE_PROVIDER = AZURE
  ENABLED = TRUE
  AZURE_TENANT_ID = '<MY_TENANT_ID>'
  STORAGE_ALLOWED_LOCATIONS = (
    'azure://<MY_CONTAINER_PATH>'
  );

